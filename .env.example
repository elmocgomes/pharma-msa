# Supabase PostgreSQL (use pooler URL for connection pooling)
DATABASE_URL=postgresql://postgres.PROJECT_ID:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Redis (internal Coolify service)
REDIS_URL=redis://redis:6379

# wa-gateway
WA_GATEWAY_URL=http://wa-gateway:5001
WA_GATEWAY_KEY=your-wa-gateway-api-key

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# API
PORT=3000
NODE_ENV=production
